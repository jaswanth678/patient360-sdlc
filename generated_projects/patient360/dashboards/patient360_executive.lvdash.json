{
  "datasets": [
    {
      "name": "exec_kpi",
      "displayName": "Executive KPI — Patient Counts",
      "queryLines": [
        "SELECT COUNT(DISTINCT patient_id) AS total_patients, ",
        "SUM(total_appointments) AS total_appointments, ",
        "COUNT(DISTINCT CASE WHEN last_appointment_date >= date_sub(current_date(), 90) THEN patient_id END) AS active_patients ",
        "FROM sdlc_catalog.patient_360_gold.patient_360_master"
      ]
    },
    {
      "name": "exec_kpi_fin",
      "displayName": "Executive KPI — Financial",
      "queryLines": [
        "SELECT ROUND(SUM(total_treatment_cost), 0) AS total_revenue_inr, ",
        "ROUND(AVG(total_treatment_cost), 0) AS avg_treatment_cost_inr, ",
        "ROUND(AVG(insurance_coverage_pct) / 100, 4) AS avg_insurance_pct ",
        "FROM sdlc_catalog.patient_360_gold.patient_financial_summary"
      ]
    },
    {
      "name": "exec_by_state",
      "displayName": "Patients & Revenue by State",
      "queryLines": [
        "SELECT m.state, ",
        "COUNT(DISTINCT m.patient_id) AS patient_count, ",
        "SUM(m.total_appointments) AS total_appointments, ",
        "ROUND(SUM(f.total_treatment_cost), 0) AS total_revenue_inr, ",
        "ROUND(AVG(f.total_treatment_cost), 0) AS avg_treatment_cost_inr ",
        "FROM sdlc_catalog.patient_360_gold.patient_360_master m ",
        "JOIN sdlc_catalog.patient_360_gold.patient_financial_summary f ON m.patient_id = f.patient_id ",
        "WHERE m.state IS NOT NULL ",
        "GROUP BY m.state ",
        "ORDER BY total_revenue_inr DESC"
      ]
    },
    {
      "name": "exec_appt_trend",
      "displayName": "Monthly Patient Trend",
      "queryLines": [
        "SELECT DATE_TRUNC('MONTH', last_appointment_date) AS appt_month, ",
        "COUNT(DISTINCT patient_id) AS patient_count, ",
        "SUM(total_appointments) AS total_appointments ",
        "FROM sdlc_catalog.patient_360_gold.patient_360_master ",
        "WHERE last_appointment_date IS NOT NULL ",
        "GROUP BY DATE_TRUNC('MONTH', last_appointment_date) ",
        "ORDER BY appt_month"
      ]
    },
    {
      "name": "exec_age_dist",
      "displayName": "Patient Age Distribution",
      "queryLines": [
        "SELECT CASE WHEN age < 18 THEN '0-17' WHEN age < 35 THEN '18-34' ",
        "WHEN age < 50 THEN '35-49' WHEN age < 65 THEN '50-64' ELSE '65+' END AS age_group, ",
        "COUNT(patient_id) AS patient_count ",
        "FROM sdlc_catalog.patient_360_gold.patient_360_master ",
        "GROUP BY 1 ORDER BY 1"
      ]
    },
    {
      "name": "exec_sex_dist",
      "displayName": "Patient Sex Distribution",
      "queryLines": [
        "SELECT COALESCE(sex, 'Unknown') AS sex, ",
        "COUNT(DISTINCT patient_id) AS patient_count ",
        "FROM sdlc_catalog.patient_360_gold.patient_360_master ",
        "GROUP BY sex ORDER BY patient_count DESC"
      ]
    }
  ],
