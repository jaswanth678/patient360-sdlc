          },
          "position": {"x": 0, "y": 21, "width": 12, "height": 1}
        },
        {
          "widget": {
            "name": "table-risk-detail",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "clin_risk_detail",
              "fields": [
                {"name": "patient_id", "expression": "`patient_id`"},
                {"name": "risk_category", "expression": "`risk_category`"},
                {"name": "overall_risk_score", "expression": "`overall_risk_score`"},
                {"name": "age_risk", "expression": "`age_risk`"},
                {"name": "lab_risk", "expression": "`lab_risk`"},
                {"name": "financial_risk", "expression": "`financial_risk`"},
                {"name": "total_appointments", "expression": "`total_appointments`"},
