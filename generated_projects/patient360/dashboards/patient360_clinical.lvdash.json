{
  "datasets": [
    {
      "name": "clin_kpi_lab",
      "displayName": "Clinical KPI — Lab & Diagnoses",
      "queryLines": [
        "SELECT COUNT(patient_id) AS total_patients, ",
        "SUM(unique_diseases) AS total_disease_records, ",
        "ROUND(SUM(above_normal_count + below_normal_count) * 100.0 / NULLIF(SUM(total_lab_tests), 0), 2) / 100 AS lab_abnormality_pct, ",
        "COUNT(CASE WHEN lab_risk_flag = true THEN patient_id END) AS lab_risk_patients, ",
        "SUM(active_med_count) AS total_active_medications ",
        "FROM sdlc_catalog.patient_360_gold.patient_clinical_summary"
      ]
    },
    {
      "name": "clin_kpi_adherence",
      "displayName": "Clinical KPI — Medication Adherence",
      "queryLines": [
        "SELECT ROUND(AVG(adherence_rate) / 100, 4) AS avg_adherence_rate ",
        "FROM sdlc_catalog.patient_360_gold.medication_adherence_summary ",
        "WHERE disease IS NOT NULL AND disease != ''"
      ]
    },
    {
      "name": "clin_by_risk",
      "displayName": "Patient Risk Category Summary",
      "queryLines": [
        "SELECT risk_category, ",
        "COUNT(patient_id) AS patient_count, ",
        "ROUND(AVG(overall_risk_score), 2) AS avg_risk_score ",
        "FROM sdlc_catalog.patient_360_gold.patient_risk_summary ",
        "GROUP BY risk_category ",
        "ORDER BY avg_risk_score DESC"
      ]
    },
    {
      "name": "clin_disease_dist",
      "displayName": "Disease Distribution",
      "queryLines": [
        "SELECT primary_disease, ",
        "COUNT(DISTINCT patient_id) AS patient_count ",
        "FROM sdlc_catalog.patient_360_gold.patient_360_master ",
        "WHERE primary_disease IS NOT NULL ",
        "GROUP BY primary_disease ",
        "ORDER BY patient_count DESC ",
        "LIMIT 10"
      ]
    },
    {
      "name": "clin_adherence_detail",
      "displayName": "Medication Adherence by Disease",
      "queryLines": [
        "SELECT disease, ",
        "COUNT(DISTINCT patient_id) AS patient_count, ",
        "ROUND(AVG(adherence_rate) / 100, 4) AS avg_adherence_rate, ",
        "ROUND(SUM(total_medicine_cost), 0) AS total_medicine_cost ",
        "FROM sdlc_catalog.patient_360_gold.medication_adherence_summary ",
        "WHERE disease IS NOT NULL AND disease != '' ",
        "GROUP BY disease ",
        "ORDER BY avg_adherence_rate ASC"
      ]
    },
    {
      "name": "clin_risk_detail",
      "displayName": "Patient Risk Detail",
      "queryLines": [
        "SELECT r.patient_id, r.risk_category, r.overall_risk_score, ",
        "r.age_risk, r.lab_risk, r.financial_risk, ",
        "m.total_appointments, ",
        "ROUND(m.total_treatment_cost, 0) AS total_treatment_cost ",
        "FROM sdlc_catalog.patient_360_gold.patient_risk_summary r ",
        "JOIN sdlc_catalog.patient_360_gold.patient_360_master m ON r.patient_id = m.patient_id ",
        "ORDER BY r.overall_risk_score DESC ",
        "LIMIT 50"
      ]
    }
  ],
  "pages": [
    {
      "name": "clinical_overview",
      "displayName": "Clinical Overview",
      "pageType": "PAGE_TYPE_CANVAS",
      "layoutVersion": "GRID_V1",
      "layout": [
        {
          "widget": {
            "name": "title",
            "multilineTextboxSpec": {"lines": ["## Patient360 — Clinical Dashboard"]}
          },
          "position": {"x": 0, "y": 0, "width": 12, "height": 1}
        },
        {
          "widget": {
            "name": "subtitle",
            "multilineTextboxSpec": {"lines": ["Clinical analysis: disease distribution, lab trends, risk stratification, and medication adherence"]}
          },
          "position": {"x": 0, "y": 1, "width": 12, "height": 1}
        },
        {
          "widget": {
            "name": "kpi-lab-risk-patients",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "clin_kpi_lab",
              "fields": [{"name": "lab_risk_patients", "expression": "`lab_risk_patients`"}],
              "disaggregated": true
            }}],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "lab_risk_patients",
                  "displayName": "Lab Risk Patients",
                  "format": {"type": "number"}
                }
              },
              "frame": {"title": "Lab Risk Patients", "showTitle": true}
            }
          },
          "position": {"x": 0, "y": 2, "width": 4, "height": 3}
        },
        {
          "widget": {
            "name": "kpi-lab-abnormality",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "clin_kpi_lab",
              "fields": [{"name": "lab_abnormality_pct", "expression": "`lab_abnormality_pct`"}],
              "disaggregated": true
            }}],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "lab_abnormality_pct",
                  "displayName": "Lab Abnormality Rate",
                  "format": {
                    "type": "number-percent",
                    "decimalPlaces": {"type": "max", "places": 2}
                  }
                }
              },
              "frame": {"title": "Lab Abnormality Rate", "showTitle": true}
            }
          },
          "position": {"x": 4, "y": 2, "width": 4, "height": 3}
        },
        {
          "widget": {
            "name": "kpi-avg-adherence",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "clin_kpi_adherence",
              "fields": [{"name": "avg_adherence_rate", "expression": "`avg_adherence_rate`"}],
              "disaggregated": true
            }}],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "avg_adherence_rate",
                  "displayName": "Avg Medication Adherence",
                  "format": {
                    "type": "number-percent",
                    "decimalPlaces": {"type": "max", "places": 1}
                  }
                }
              },
              "frame": {"title": "Avg Medication Adherence %", "showTitle": true}
            }
          },
          "position": {"x": 8, "y": 2, "width": 4, "height": 3}
        },
        {
          "widget": {
            "name": "kpi-unique-diseases",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "clin_disease_dist",
              "fields": [{"name": "count(primary_disease)", "expression": "COUNT(`primary_disease`)"}],
              "disaggregated": false
            }}],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "count(primary_disease)",
                  "displayName": "Unique Diseases",
                  "format": {"type": "number"}
                }
              },
              "frame": {"title": "Unique Diseases (Top 10)", "showTitle": true}
            }
          },
          "position": {"x": 0, "y": 5, "width": 4, "height": 3}
        },
        {
          "widget": {
            "name": "kpi-total-active-meds",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "clin_kpi_lab",
              "fields": [{"name": "total_active_medications", "expression": "`total_active_medications`"}],
              "disaggregated": true
            }}],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "total_active_medications",
                  "displayName": "Active Medications",
                  "format": {"type": "number"}
                }
              },
              "frame": {"title": "Total Active Medications", "showTitle": true}
            }
          },
          "position": {"x": 4, "y": 5, "width": 4, "height": 3}
        },
        {
          "widget": {
            "name": "kpi-total-disease-records",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "clin_kpi_lab",
              "fields": [{"name": "total_disease_records", "expression": "`total_disease_records`"}],
              "disaggregated": true
            }}],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "total_disease_records",
                  "displayName": "Total Disease Records",
                  "format": {"type": "number"}
                }
              },
              "frame": {"title": "Total Diagnosis Records", "showTitle": true}
            }
          },
          "position": {"x": 8, "y": 5, "width": 4, "height": 3}
        },
        {
          "widget": {
            "name": "section-disease-risk",
            "multilineTextboxSpec": {"lines": ["### Disease Distribution & Risk Analysis"]}
          },
          "position": {"x": 0, "y": 8, "width": 12, "height": 1}
        },
        {
          "widget": {
            "name": "chart-disease-dist",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "clin_disease_dist",
              "fields": [
                {"name": "primary_disease", "expression": "`primary_disease`"},
                {"name": "patient_count", "expression": "`patient_count`"}
              ],
              "disaggregated": true
            }}],
            "spec": {
              "version": 3,
              "widgetType": "pie",
              "encodings": {
                "angle": {"fieldName": "patient_count", "displayName": "Patients", "scale": {"type": "quantitative"}},
                "color": {"fieldName": "primary_disease", "displayName": "Disease", "scale": {"type": "categorical"}}
