                  {"fieldName": "overall_risk_score", "displayName": "Risk Score"},
                  {"fieldName": "age_risk", "displayName": "Age Risk"},
                  {"fieldName": "lab_risk", "displayName": "Lab Risk"},
                  {"fieldName": "financial_risk", "displayName": "Financial Risk"},
                  {"fieldName": "total_appointments", "displayName": "Appointments"},
