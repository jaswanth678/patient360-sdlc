{
  "datasets": [
    {
      "name": "op_kpi",
      "displayName": "Operational KPI Summary",
      "queryLines": [
        "SELECT COUNT(DISTINCT doctor_name) AS total_doctors, ",
        "COUNT(DISTINCT department) AS total_departments, ",
        "SUM(total_appointments) AS total_appointments, ",
        "SUM(unique_patients) AS total_unique_patients, ",
        "ROUND(SUM(total_revenue_inr), 0) AS total_revenue_inr ",
        "FROM sdlc_catalog.patient_360_gold.doctor_performance_summary"
      ]
    },
    {
      "name": "op_by_dept",
      "displayName": "Department Workload",
      "queryLines": [
        "SELECT department, ",
        "SUM(total_appointments) AS total_appointments, ",
        "COUNT(DISTINCT doctore_id) AS doctor_count, ",
        "SUM(unique_patients) AS total_patients ",
        "FROM sdlc_catalog.patient_360_gold.doctor_performance_summary ",
        "GROUP BY department ",
        "ORDER BY total_appointments DESC"
      ]
    },
    {
      "name": "op_doctor_perf",
      "displayName": "Doctor Performance",
      "queryLines": [
        "SELECT doctor_name, department, ",
        "total_appointments, unique_patients, ",
        "ROUND(avg_charge_inr, 0) AS avg_charge_inr, ",
        "ROUND(total_revenue_inr, 0) AS total_revenue_inr ",
        "FROM sdlc_catalog.patient_360_gold.doctor_performance_summary ",
        "ORDER BY total_appointments DESC ",
        "LIMIT 15"
      ]
    },
    {
      "name": "op_revenue_by_doctor",
      "displayName": "Revenue by Doctor",
      "queryLines": [
        "SELECT doctor_name, ",
        "ROUND(total_revenue_inr, 0) AS total_revenue_inr, ",
        "total_appointments ",
        "FROM sdlc_catalog.patient_360_gold.doctor_performance_summary ",
        "WHERE total_revenue_inr IS NOT NULL ",
        "ORDER BY total_revenue_inr DESC ",
        "LIMIT 12"
      ]
    },
    {
      "name": "op_age_dist_master",
      "displayName": "Patient Age Distribution",
      "queryLines": [
        "SELECT CASE WHEN age < 18 THEN '0-17' WHEN age < 35 THEN '18-34' ",
        "WHEN age < 50 THEN '35-49' WHEN age < 65 THEN '50-64' ELSE '65+' END AS age_group, ",
        "COUNT(patient_id) AS patient_count ",
        "FROM sdlc_catalog.patient_360_gold.patient_360_master ",
        "GROUP BY 1 ORDER BY 1"
      ]
    }
  ],
  "pages": [
    {
      "name": "operational_overview",
      "displayName": "Operational Overview",
      "pageType": "PAGE_TYPE_CANVAS",
      "layoutVersion": "GRID_V1",
      "layout": [
        {
          "widget": {
            "name": "title",
            "multilineTextboxSpec": {"lines": ["## Patient360 — Operational Dashboard"]}
          },
          "position": {"x": 0, "y": 0, "width": 12, "height": 1}
        },
        {
          "widget": {
            "name": "subtitle",
            "multilineTextboxSpec": {"lines": ["Doctor performance, department workload, and patient visit patterns for operational administrators"]}
          },
          "position": {"x": 0, "y": 1, "width": 12, "height": 1}
        },
        {
          "widget": {
            "name": "kpi-total-doctors",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "op_kpi",
              "fields": [{"name": "total_doctors", "expression": "`total_doctors`"}],
              "disaggregated": true
            }}],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "total_doctors",
                  "displayName": "Total Doctors",
                  "format": {"type": "number"}
                }
              },
              "frame": {"title": "Total Active Doctors", "showTitle": true}
            }
          },
          "position": {"x": 0, "y": 2, "width": 4, "height": 3}
        },
        {
          "widget": {
            "name": "kpi-total-appointments",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "op_kpi",
              "fields": [{"name": "total_appointments", "expression": "`total_appointments`"}],
              "disaggregated": true
            }}],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "total_appointments",
                  "displayName": "Total Appointments",
                  "format": {"type": "number"}
                }
              },
              "frame": {"title": "Total Appointments", "showTitle": true}
            }
          },
          "position": {"x": 4, "y": 2, "width": 4, "height": 3}
        },
        {
          "widget": {
            "name": "kpi-total-departments",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "op_kpi",
              "fields": [{"name": "total_departments", "expression": "`total_departments`"}],
              "disaggregated": true
            }}],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
