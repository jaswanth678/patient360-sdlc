        {
          "widget": {
            "name": "kpi-total-unique-patients",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "op_kpi",
              "fields": [{"name": "total_unique_patients", "expression": "`total_unique_patients`"}],
              "disaggregated": true
            }}],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "total_unique_patients",
                  "displayName": "Unique Patients",
                  "format": {"type": "number"}
                }
              },
              "frame": {"title": "Total Unique Patients", "showTitle": true}
