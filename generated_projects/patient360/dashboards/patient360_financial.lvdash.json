{
  "datasets": [
    {
      "name": "fin_kpi",
      "displayName": "Financial KPI Summary",
      "queryLines": [
        "SELECT ROUND(SUM(total_treatment_cost), 0) AS total_revenue_inr, ",
        "ROUND(AVG(total_treatment_cost), 0) AS avg_treatment_cost_inr, ",
        "ROUND(AVG(insurance_coverage_pct) / 100, 4) AS avg_insurance_pct, ",
        "SUM(paid_bills) AS total_paid_bills, ",
        "SUM(total_bills) AS total_bills, ",
        "SUM(upi_payments) AS total_upi_payments, ",
        "SUM(cash_payments) AS total_cash_payments ",
        "FROM sdlc_catalog.patient_360_gold.patient_financial_summary"
      ]
    },
    {
      "name": "fin_by_state",
      "displayName": "Revenue & Patients by State",
      "queryLines": [
        "SELECT m.state, ",
        "COUNT(DISTINCT m.patient_id) AS patient_count, ",
        "ROUND(SUM(f.total_treatment_cost), 0) AS total_revenue_inr, ",
        "ROUND(AVG(f.total_treatment_cost), 0) AS avg_treatment_cost_inr, ",
        "ROUND(AVG(f.insurance_coverage_pct) / 100, 4) AS avg_insurance_pct, ",
        "SUM(f.paid_bills) AS paid_bills, ",
        "SUM(f.total_bills) AS total_bills ",
        "FROM sdlc_catalog.patient_360_gold.patient_360_master m ",
        "JOIN sdlc_catalog.patient_360_gold.patient_financial_summary f ON m.patient_id = f.patient_id ",
        "WHERE m.state IS NOT NULL ",
        "GROUP BY m.state ",
        "ORDER BY total_revenue_inr DESC"
      ]
    },
    {
      "name": "fin_payment_mode",
      "displayName": "Payment Mode Distribution",
      "queryLines": [
        "SELECT 'UPI' AS payment_mode, SUM(upi_payments) AS transaction_count ",
        "FROM sdlc_catalog.patient_360_gold.patient_financial_summary ",
        "UNION ALL ",
        "SELECT 'CASH' AS payment_mode, SUM(cash_payments) AS transaction_count ",
        "FROM sdlc_catalog.patient_360_gold.patient_financial_summary"
      ]
    },
    {
      "name": "fin_rev_trend",
      "displayName": "Monthly Revenue Trend",
      "queryLines": [
        "SELECT DATE_TRUNC('MONTH', m.last_appointment_date) AS revenue_month, ",
        "ROUND(SUM(f.total_treatment_cost), 0) AS monthly_revenue, ",
        "COUNT(DISTINCT f.patient_id) AS patient_count ",
        "FROM sdlc_catalog.patient_360_gold.patient_financial_summary f ",
        "JOIN sdlc_catalog.patient_360_gold.patient_360_master m ON f.patient_id = m.patient_id ",
        "WHERE m.last_appointment_date IS NOT NULL ",
        "GROUP BY DATE_TRUNC('MONTH', m.last_appointment_date) ",
        "ORDER BY revenue_month"
      ]
    },
    {
      "name": "fin_patient_detail",
      "displayName": "Patient Financial Detail",
      "queryLines": [
        "SELECT f.patient_id, m.state, ",
        "ROUND(f.total_treatment_cost, 0) AS total_cost, ",
        "ROUND(f.total_insurance_coverage, 0) AS insurance_covered, ",
        "ROUND(f.total_treatment_cost - f.total_insurance_coverage, 0) AS out_of_pocket, ",
        "ROUND(f.insurance_coverage_pct, 2) AS coverage_pct, ",
        "f.upi_payments, f.cash_payments, ",
        "f.paid_bills, f.total_bills ",
        "FROM sdlc_catalog.patient_360_gold.patient_financial_summary f ",
        "JOIN sdlc_catalog.patient_360_gold.patient_360_master m ON f.patient_id = m.patient_id ",
        "ORDER BY out_of_pocket DESC ",
        "LIMIT 50"
      ]
    }
  ],
  "pages": [
